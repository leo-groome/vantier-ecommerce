# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@vantier.com
RESEND_SUPPORT_EMAIL=luxury@vantiersupport.com

# Storage (Cloudflare R2 or Supabase)
STORAGE_URL=https://...

# App
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]
