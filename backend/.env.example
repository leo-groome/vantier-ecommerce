# Database (Neon.tech)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# Neon Auth (JWT validation)
NEON_AUTH_JWKS_URL=https://your-neon-project.neonauth.<region>.aws.neon.tech/<db>/auth/.well-known/jwks.json
# NEON_AUTH_AUDIENCE must match the 'aud' claim in the JWT issued by Neon Auth.
# For Neon Auth (Better Auth backend), this is the base URL of the auth endpoint,
# NOT "authenticated" (that is a Supabase convention).
# Example: https://ep-still-poetry-ak684mdd.neonauth.c-3.us-west-2.aws.neon.tech
NEON_AUTH_AUDIENCE=https://your-neon-project.neonauth.<region>.aws.neon.tech

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# envia.com
ENVIA_API_KEY=...
ENVIA_BASE_URL=https://api.envia.com

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@vantier.com
RESEND_SUPPORT_EMAIL=luxury@vantiersupport.com

# Storage — Cloudflare R2
STORAGE_URL=https://pub-<hash>.r2.dev
CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_BUCKET=vantier-images
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173"]

# Dev auth bypass — ONLY for local pytest. NEVER set in production/staging.
# Allows tokens starting with "dev_token_" to skip JWT verification.
# ENABLE_DEV_AUTH=true
