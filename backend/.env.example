# Neon Auth (JWT validation)
NEON_AUTH_JWKS_URL=https://your-neon-project.neon.tech/.well-known/jwks.json
NEON_AUTH_AUDIENCE=your-audience

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# envia.com
ENVIA_API_KEY=...
